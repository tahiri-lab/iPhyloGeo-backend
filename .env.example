# URL of the React frontend (used in CORS allowlist)
FRONTEND_URL=http://localhost:5173

# MongoDB — must match the docker-compose in iPhyloGeo/
MONGO_URI=mongodb://localhost:27018
DB_NAME=iphylogeo

# Redis — must match the docker-compose in iPhyloGeo/  (host port 6380 → container 6379)
REDIS_URL=redis://localhost:6380

# Email (Gmail SMTP)
EMAIL_USER=iphylogeo@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Temporary result TTL in seconds (used when user declines persistent storage)
TEMP_RESULT_TTL_SECONDS=7200
